import java.util.Scanner;
public class Main{
    public static void main(String[] args){
        Scanner sc=new Scanner(System.in);
        int a=sc.nextInt();
        int b=sc.nextInt();
        int c=sc.nextInt();
        int total=a+b+c;
        double avg=(float)total/3.0;
        System.out.println("Total Marks: "+total);
        System.out.printf("Average Marks: %.2f",avg);
        }
}
