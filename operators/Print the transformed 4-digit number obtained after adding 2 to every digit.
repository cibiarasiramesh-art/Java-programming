import java.util.Scanner;
public class Main{
    public static void main(String[] args){
        Scanner sc=new Scanner(System.in);
        int n=sc.nextInt();
       int d1 =(n/1000+2)%10;
        int d2=((n/100)%10+2)%10;
        int d3=((n/10)%10+2)%10;
        int d4=(n%10+2)%10;
        
        
        
        System.out.println(""+d1+d2+d3+d4);
        
    }
}
