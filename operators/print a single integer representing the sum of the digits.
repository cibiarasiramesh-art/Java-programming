import java.util.Scanner;
public class Main{
    public static void main(String[] args){
        Scanner sc=new Scanner(System.in);
        int n=sc.nextInt();
        int a=n/100;
        int res=a;
        int b=(n/10)%10;
        res+=b;
        int c=(n%10);
        res+=c;
        System.out.println(res);
    }
}
