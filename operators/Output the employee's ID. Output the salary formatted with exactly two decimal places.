import java.util.Scanner;
public class Main{
    public static void main(String[] args){
        Scanner sc=new Scanner(System.in);
        String n=sc.nextLine();
        int h=sc.nextInt();
        int r=sc.nextInt();
        System.out.println("Employee's ID = "+n);
        float res=(float)h*r;
        System.out.printf("Salary = Rs. %.2f ",res);
    }
}
