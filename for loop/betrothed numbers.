import java.util.*;
public class Main{
    public static void main(String[] args){
        Scanner sc=new Scanner(System.in);
        int n=sc.nextInt();
        int m=sc.nextInt();
        int sum1=0,sum2=0;
        for(int i=1;i<n;i++){
            if(n%i==0){
                 sum1+=i;
            }
           
        }
        for(int i=1;i<m;i++){
            if(m%i==0){
                 sum2+=i;
            }
            
        }
        if((sum1==m+1)&&(sum2==n+1)){
            System.out.print("Yes");
        }
        else{
            System.out.print("No");
        }
    }
}
