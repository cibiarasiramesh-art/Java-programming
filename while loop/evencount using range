import java.util.Scanner;
public class evensum{
    public static void main(String[]args){
        Scanner sc=new Scanner(System.in);
        int s=sc.nextInt();
        int e=sc.nextInt();
        int st=s;
        int add=0;
        while(s<e){
            if(s%2==0){
                add=add+s;
            }
            s++;

        }
        System.out.println("Sum of the even numbers from "+st+ " to " +e+ " : "+add);
    }
}
