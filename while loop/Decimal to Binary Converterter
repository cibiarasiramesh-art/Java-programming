import java.util.Scanner;
public class Main{
    public static void main(String[]args){
        Scanner sc=new Scanner(System.in);
        int n=sc.nextInt();
         int place=1;
        int add=0;
         while(n>0){
             int rem=n%2;
             int quo=n/2;
             add=add+(rem*place);
             place=place*10;
             n=quo;
        }
       
      
        System.out.println(add);
      
    }
}
