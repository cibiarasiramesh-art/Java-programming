import java.util.Scanner;
public class Main{
    public static void main(String[] args){
        Scanner sc=new Scanner(System.in);
        int n=sc.nextInt();
        int count=Math.abs(n);
        int a=0;int b=1;int i=0;
        while(i<count){
            int value=a;
            if(n<0 && i!=0 && i%2==0){
                value=-value;
            }
            System.out.println(value);
            int c=a+b;
            a=b;
            b=c;
            i++;
        }
    }
}
