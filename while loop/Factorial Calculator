import java.util.Scanner;
public class Main{
    public static void main(String[] args){
        Scanner sc=new Scanner(System.in);
        int n=sc.nextInt();
        int v=n;
        int fact=1;
        while(n>0){
            fact=fact*n;
           n--;
        }
         System.out.println("factorial of "+v+" = "+fact);
    }
}
