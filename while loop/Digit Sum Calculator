import java.util.Scanner;
public class Main{
    public static void main(String[] args){
        Scanner sc=new Scanner(System.in);
        int n=sc.nextInt();
        System.out.println("number: "+n);
        int count=0;
        while(n!=0){
            int rem=n%10;
            count=count+rem;
            n=n/10;
        }
        
        System.out.println("sum of digits: "+count);
    }
}
