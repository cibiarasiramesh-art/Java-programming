import java.util.Scanner;
public class Multiplicationtable {
    public static void main(String[] args){
        Scanner sc=new Scanner(System.in);
        int n=sc.nextInt();
        int r=sc.nextInt();
        int i=1;
        while(i<=r){
            System.out.println(n+" X "+i+" = "+n*i);
            i++;
        }
    }
}
