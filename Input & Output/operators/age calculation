import java.util.Scanner;
public class Main{
    public static void main(String[] args){
        Scanner sc=new Scanner(System.in);
        int a=sc.nextInt();
        int m=a*12;
        int d=a*365;
        long h=a*365*24;
        long s=a*365*24*3600;
        System.out.println("Ages in Months: "+m);
        System.out.println("Ages in Days: "+d);
        System.out.println("Ages in Hours: "+h);
        System.out.println("Ages in Seconds: "+s);
    }
}
